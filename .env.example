# ─────────────────────────────────────────────────────────────
# Syslog AI Monitor — configuration
# Copy this file to ".env" and fill in your values:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Anthropic API (required) — get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Evaluation schedule & retention
EVAL_INTERVAL_MINUTES=60      # how often to evaluate. 60 = top of every hour
                             # (9:00, 10:00). Divisors of 60 (30, 15, ...) align
                             # to the hour too; other values run from start.
RETENTION_DAYS=30            # how long to keep AI findings (history)

# Weekly pattern review — rolls up recent hourly findings to surface recurring
# issues and trends. Runs once a day over a rolling window.
WEEKLY_WINDOW_DAYS=7         # how many days of findings to review
WEEKLY_REVIEW_HOUR=6         # local hour-of-day (0-23) to run the review

# Timezone for scheduling + log timestamps (IANA name). Set this so evaluations
# land on YOUR local top-of-hour, not UTC. e.g. America/Chicago, America/New_York
TZ=America/Chicago

# Network ports
SYSLOG_PORT=514               # UDM Pro sends syslog here (UDP + TCP)
WEB_PORT=8080                 # dashboard: http://<pi-ip>:8080

# Digest limits (controls token/cost per evaluation)
DIGEST_MAX_TEMPLATES=60       # top-N distinct message patterns to send
DIGEST_MAX_SAMPLES=200        # max elevated-severity sample lines to send
DIGEST_MAX_CHARS=24000        # hard cap on digest size sent to the model

# ─────────────────────────────────────────────────────────────
# Email alerts (optional) — leave SMTP_HOST blank to disable email
# Gmail: use an App Password (https://myaccount.google.com/apppasswords),
#        SMTP_HOST=smtp.gmail.com  SMTP_PORT=587
# ─────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM=syslog-pi@example.com
ALERT_TO=jeff@strout.us
ALERT_MIN_SEVERITY=error      # email when a finding is this severity or higher:
                              # info < warning < error < critical
